# .gitignore

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json   # optional — many teams now commit it, but if you prefer not to:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Build output
/dist
/build
/.tscache
/.tsbuildinfo

# Environment variables
.env
.env.local
.env.development
.env.production
.env.*.local

# Docker
Dockerfile*.local
.dockerignore

# Logs
logs/
*.log

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.sublime-*

# Testing / Coverage
/coverage
.nyc_output

# Optional: if you use Prisma (you don't, but just in case later)
/prisma/migrations/